# GitHub API 配置示例
# 复制此文件为 .env 并填写实际的配置值

# 环境选择 (dev/test/staging/prod)
ENV=test

# GitHub API 配置
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=your_github_personal_access_token_here

# GitHub 测试数据
TEST_GITHUB_USER=octocat
TEST_GITHUB_REPO=Hello-World

# GitHub API 频率限制配置
GITHUB_RATE_LIMIT=5000
GITHUB_RATE_LIMIT_WINDOW=3600

# 企业级特性配置
ENABLE_CIRCUIT_BREAKER=true
ENABLE_RATE_LIMITER=true
ENABLE_PLUGINS=true

# Mock 配置
# USE_MOCK=true（默认）：使用 Mock 数据进行测试
# USE_MOCK=false：使用真实 API 请求（需要配置 GITHUB_TOKEN）
USE_MOCK=true

# API 配置
API_TIMEOUT=30
API_VERIFY_SSL=true

# UI 配置（如果需要）
BROWSER=chrome
HEADLESS=true
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080
WAIT_TIMEOUT=10

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=test.log

# 报告配置
REPORT_DIR=reports
ALLURE_DIR=reports/allure_results
SCREENSHOT_DIR=reports/screenshots
SCREENSHOT_ON_FAILURE=true

# 加密密钥（用于敏感信息加密）
# 可以使用 Python 生成: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
ENCRYPTION_KEY=your_encryption_key_here

# 如何获取 GitHub Token:
# 1. 访问 https://github.com/settings/tokens
# 2. 点击 "Generate new token (classic)"
# 3. 选择权限：public_repo, read:user, user:email
# 4. 生成并复制 token
# 5. 粘贴到上面的 GITHUB_TOKEN 配置项
